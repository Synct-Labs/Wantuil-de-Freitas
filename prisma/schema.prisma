generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Perfil {
  MASTER
  ADMIN
  ALMOXARIFE
  GESTOR
  OPERADOR
}

enum TipoPessoa {
  PF
  PJ
}

enum TipoMovimentacao {
  ENTRADA
  SAIDA
  ESTORNO
  DESCARTE
}

enum DestinoSaida {
  BENEFICIARIO
  SETOR
  EVENTO
}

enum StatusEvento {
  PLANEJADO
  EM_ANDAMENTO
  FINALIZADO
  CANCELADO
}

enum StatusValidade {
  VIGENTE
  PROXIMO
  VENCIDO
  ADICIONAL
  DESCARTE
}

model Usuario {
  id            String   @id @default(uuid())
  nome          String
  email         String   @unique
  senha         String
  perfil        Perfil   @default(OPERADOR)
  ativo         Boolean  @default(true)
  receberEmail  Boolean  @default(true) @map("receber_email")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  movimentacoes Movimentacao[]
  logs          LogAuditoria[]
  tokensSenha   TokenSenha[]

  @@map("usuarios")
}

/// Token de uso unico para o usuario definir sua propria senha.
/// Usado em dois fluxos: (a) convite ao criar usuario novo;
/// (b) recuperacao de senha esquecida via "Esqueci minha senha".
model TokenSenha {
  id        String   @id @default(uuid())
  token     String   @unique // string aleatoria gerada com crypto.randomBytes
  usuarioId String   @map("usuario_id")
  tipo      String   // 'CONVITE' (7 dias) ou 'RESET' (1 hora)
  expiraEm  DateTime @map("expira_em")
  usado     Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("tokens_senha")
}

model Categoria {
  id        String   @id @default(uuid())
  nome      String   @unique
  descricao String?
  itens     Item[]
  createdAt DateTime @default(now())

  @@map("categorias")
}

model Setor {
  id          String   @id @default(uuid())
  nome        String   @unique
  responsavel String?
  ativo       Boolean  @default(true)
  createdAt   DateTime @default(now())

  itens         Item[]
  movimentacoes Movimentacao[]
  lotes         Lote[]

  @@map("setores")
}

/// Produto base agrega VARIAS marcas/variacoes do mesmo produto.
/// Ex: "Arroz 5kg" e o produto base de "Arroz Tio Joao 5kg" e "Arroz Camil 5kg".
/// O estoque minimo passa a ser definido no produto base (nao mais no item)
/// e os alertas comparam a SOMA do saldo das marcas com o minimo do produto base.
///
/// Campo no Item permanece opcional para preservar compatibilidade com
/// itens cadastrados antes da reforma.
model ProdutoBase {
  id              String   @id @default(uuid())
  nome            String   @unique
  unidadeMedida   String   @default("un") @map("unidade_medida")
  estoqueMinimo   Decimal  @default(0) @map("estoque_minimo") @db.Decimal(10, 2)
  ativo           Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  itens Item[]

  @@map("produtos_base")
}

model Item {
  id            String    @id @default(uuid())
  codigoInterno String    @unique @map("codigo_interno")
  codigoEan     String?   @map("codigo_ean")
  nome          String
  descricao     String?
  unidadeMedida String    @default("un") @map("unidade_medida")
  estoqueMinimo Decimal   @default(0) @map("estoque_minimo") @db.Decimal(10, 2)
  saldoAtual    Decimal   @default(0) @map("saldo_atual") @db.Decimal(10, 2)
  // dataValidade e localizacao agora ficam no Lote (deprecated aqui, mantido para compat)
  dataValidade  DateTime? @map("data_validade") @db.Date
  localizacao   String?
  ativo         Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  categoriaId String    @map("categoria_id")
  categoria   Categoria @relation(fields: [categoriaId], references: [id])
  setorId     String?   @map("setor_id")

  // Vinculo opcional com produto base. Se preenchido, alertas e relatorios
  // agregam por este produto. Se vazio, item se comporta isolado.
  produtoBaseId String?      @map("produto_base_id")
  produtoBase   ProdutoBase? @relation(fields: [produtoBaseId], references: [id])
  setor       Setor?    @relation(fields: [setorId], references: [id])

  lotes             Lote[]
  movimentacaoItens MovimentacaoItem[]

  @@index([codigoEan])
  @@index([nome])
  @@map("itens")
}

// ────────────────────────────────────────────────────────────────────
// LOTE: cada entrada fisica de um item, com sua propria validade.
// Etiqueta: barcode Code128 do codigoLote (formato L-AAAAMMDD-NNNN).
// Saida: scanner le a etiqueta do lote e abate da quantidadeAtual.
// ────────────────────────────────────────────────────────────────────
model Lote {
  id                String    @id @default(uuid())
  codigoLote        String    @unique @map("codigo_lote")
  itemId            String    @map("item_id")
  item              Item      @relation(fields: [itemId], references: [id])
  quantidadeInicial Decimal   @map("quantidade_inicial") @db.Decimal(10, 2)
  quantidadeAtual   Decimal   @map("quantidade_atual") @db.Decimal(10, 2)
  dataEntrada       DateTime  @default(now()) @map("data_entrada") @db.Date
  dataValidade      DateTime? @map("data_validade") @db.Date
  doadorId          String?   @map("doador_id")
  doador            Doador?   @relation(fields: [doadorId], references: [id])
  setorId           String?   @map("setor_id")
  setor             Setor?    @relation(fields: [setorId], references: [id])
  localizacao       String?
  observacao        String?
  ativo             Boolean   @default(true)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  movimentacaoItens MovimentacaoItem[]
  reservas          ReservaEvento[]

  @@index([itemId])
  @@index([codigoLote])
  @@index([dataValidade])
  @@map("lotes")
}

// ────────────────────────────────────────────────────────────────────
// EVENTO: ação organizada que reserva e consome estoque.
// Ex: distribuição mensal, campanha de Natal, evento beneficente.
// Reservas BLOQUEIAM o saldo disponível dos lotes.
// Ao FINALIZAR, sobras voltam automaticamente ao estoque.
// ────────────────────────────────────────────────────────────────────
model Evento {
  id           String       @id @default(uuid())
  nome         String
  descricao    String?
  dataInicio   DateTime     @map("data_inicio") @db.Date
  dataFim      DateTime?    @map("data_fim") @db.Date
  responsavel  String?
  status       StatusEvento @default(PLANEJADO)
  observacao   String?
  finalizadoEm DateTime?    @map("finalizado_em")
  ativo        Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  reservas      ReservaEvento[]
  movimentacoes Movimentacao[]

  @@index([status])
  @@map("eventos")
}

model ReservaEvento {
  id                  String   @id @default(uuid())
  eventoId            String   @map("evento_id")
  loteId              String   @map("lote_id")
  quantidadeReservada Decimal  @map("quantidade_reservada") @db.Decimal(10, 2)
  // Quando o evento finaliza/cancela ou a reserva e removida, fica inativa
  // e o saldo do lote volta a estar disponivel.
  ativa               Boolean  @default(true)
  observacao          String?
  createdAt           DateTime @default(now())

  evento Evento @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  lote   Lote   @relation(fields: [loteId], references: [id])

  @@unique([eventoId, loteId])
  @@index([loteId, ativa])
  @@map("reservas_evento")
}

model Doador {
  id         String     @id @default(uuid())
  tipo       TipoPessoa @default(PF)
  nome       String
  cpfCnpj    String     @unique @map("cpf_cnpj")
  telefone   String?
  email      String?
  endereco   String?
  observacao String?
  ativo      Boolean    @default(true)
  createdAt  DateTime   @default(now())

  movimentacoes Movimentacao[]
  lotes         Lote[]

  @@map("doadores")
}

model Beneficiario {
  id               String    @id @default(uuid())
  nome             String
  cpf              String    @unique
  dataNascimento   DateTime? @map("data_nascimento") @db.Date
  telefone         String?
  endereco         String?
  bairro           String?
  situacaoFamiliar String?   @map("situacao_familiar")
  observacao       String?
  ativo            Boolean   @default(true)
  createdAt        DateTime  @default(now())

  movimentacoes Movimentacao[]

  @@map("beneficiarios")
}

model Movimentacao {
  id                String           @id @default(uuid())
  tipo              TipoMovimentacao
  destinoSaida      DestinoSaida?    @map("destino_saida")
  dataMovimentacao  DateTime         @default(now()) @map("data_movimentacao") @db.Date
  finalidade        String?
  observacao        String?
  confirmadoMinimo  Boolean          @default(false) @map("confirmado_minimo")
  createdAt         DateTime         @default(now())

  usuarioId      String        @map("usuario_id")
  usuario        Usuario       @relation(fields: [usuarioId], references: [id])
  doadorId       String?       @map("doador_id")
  doador         Doador?       @relation(fields: [doadorId], references: [id])
  beneficiarioId String?       @map("beneficiario_id")
  beneficiario   Beneficiario? @relation(fields: [beneficiarioId], references: [id])
  setorId        String?       @map("setor_id")
  setor          Setor?        @relation(fields: [setorId], references: [id])
  eventoId       String?       @map("evento_id")
  evento         Evento?       @relation(fields: [eventoId], references: [id])
  estornoDeId    String?       @unique @map("estorno_de_id")
  estornoDe      Movimentacao? @relation("Estorno", fields: [estornoDeId], references: [id])
  estornadoPor   Movimentacao? @relation("Estorno")

  itens MovimentacaoItem[]

  @@index([dataMovimentacao])
  @@map("movimentacoes")
}

model MovimentacaoItem {
  id             String   @id @default(uuid())
  quantidade     Decimal  @db.Decimal(10, 2)
  dataValidade   DateTime? @map("data_validade") @db.Date
  saldoAnterior  Decimal  @map("saldo_anterior") @db.Decimal(10, 2)
  saldoPosterior Decimal  @map("saldo_posterior") @db.Decimal(10, 2)

  movimentacaoId String       @map("movimentacao_id")
  movimentacao   Movimentacao @relation(fields: [movimentacaoId], references: [id], onDelete: Cascade)
  itemId         String       @map("item_id")
  item           Item         @relation(fields: [itemId], references: [id])
  loteId         String?      @map("lote_id")
  lote           Lote?        @relation(fields: [loteId], references: [id])

  @@map("movimentacao_itens")
}

model LogAuditoria {
  id        String   @id @default(uuid())
  acao      String
  entidade  String
  entidadeId String? @map("entidade_id")
  detalhes  Json?
  createdAt DateTime @default(now())

  usuarioId String  @map("usuario_id")
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  @@index([createdAt])
  @@map("logs_auditoria")
}

model Notificacao {
  id        String   @id @default(uuid())
  tipo      String
  titulo    String
  mensagem  String
  lida      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("notificacoes")
}

// Catalogo crescente de produtos: cache local de EANs ja vistos.
// Alimentado automaticamente quando alguem cadastra um produto manualmente,
// e tambem quando uma API externa devolve dados (cache permanente).
model CatalogoProduto {
  id                String   @id @default(uuid())
  ean               String   @unique
  nome              String
  marca             String?
  categoria         String?
  categoriaSugerida String?  @map("categoria_sugerida")
  imagemUrl         String?  @map("imagem_url")
  fonte             String   // 'manual', 'dotcompany', 'open-food-facts', 'open-beauty-facts', 'open-products-facts'
  vezesUsado        Int      @default(1) @map("vezes_usado")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("catalogo_produtos")
  @@index([ean])
  @@index([nome])
}
